# Backend API environment variables (Spring Boot)
# MySQL connection (must align with database/db_connection.txt)
# db_connection.txt shows:
#   mysql -u appuser -pdbuser123 -h localhost -P 5000 myapp
MYSQL_URL=localhost
MYSQL_PORT=5000
MYSQL_DB=myapp
MYSQL_USER=appuser
MYSQL_PASSWORD=dbuser123

# CORS: allow the React app origin (comma-separated allowed origins)
# Example:
# FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# Enable/disable header-based security
# When enabled, provide X-USER and X-ROLE headers for protected endpoints.
app.security.enabled=true
